# API (FastAPI)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
PUBLIC_API_URL=http://localhost:8100
MAX_UPLOAD_MB=250
MAX_SR_LONG_EDGE=4096
DATA_DIR=data

# Local AuraSR-v2 (Hugging Face model id)
MODEL_ID=fal/AuraSR-v2
# auto | cuda | cpu
DEVICE=auto
# png | tiff | jpeg — default export after upscale
UPSCALE_OUTPUT_FORMAT=png
JPEG_QUALITY=98

# Web — server-side proxy to FastAPI (not exposed to browser)
API_URL=http://127.0.0.1:8100
